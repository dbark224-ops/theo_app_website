{% liquid
  assign page_variant = 'support'

  if page.handle == 'privacy-policy'
    assign page_variant = 'privacy'
  elsif page.handle == 'terms-of-service'
    assign page_variant = 'terms'
  elsif page.handle == 'contact'
    assign page_variant = 'support'
  endif
%}

{% render 'theo-marketing-content',
  page_variant: page_variant,
  support_email: section.settings.support_email,
  website_url: section.settings.website_url,
  response_window: section.settings.response_window,
  apple_store_link: section.settings.apple_store_link,
  google_play_link: section.settings.google_play_link
%}

{% schema %}
{
  "name": "Theo page router",
  "settings": [
    {
      "type": "url",
      "id": "apple_store_link",
      "label": "App Store link"
    },
    {
      "type": "url",
      "id": "google_play_link",
      "label": "Google Play link"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@theo.coach"
    },
    {
      "type": "text",
      "id": "website_url",
      "label": "Website URL",
      "default": "https://theo.coach"
    },
    {
      "type": "text",
      "id": "response_window",
      "label": "Support response window",
      "default": "Usually within 1–2 business days"
    }
  ],
  "presets": [
    {
      "name": "Theo page router"
    }
  ]
}
{% endschema %}
