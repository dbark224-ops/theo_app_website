<section class="theo-page theo-page--{{ section.settings.page_variant }}">
  <style>
    .theo-page {
      --theo-bg: #f7f0e4;
      --theo-bg-soft: #fbf7f0;
      --theo-surface: #f3e6cf;
      --theo-surface-soft: #eef6fb;
      --theo-card: rgba(255, 250, 242, 0.78);
      --theo-text: #0f0f0d;
      --theo-muted: #6c6256;
      --theo-fawn: #c6ad84;
      --theo-copper: #958263;
      --theo-stone: #635742;
      --theo-slate: #5d7380;
      --theo-steel: #8badc0;
      --theo-blue: #b9e6ff;
      --theo-border: rgba(99, 87, 66, 0.12);
      background:
        radial-gradient(circle at 12% 12%, rgba(198, 173, 132, 0.34), transparent 28%),
        radial-gradient(circle at 88% 18%, rgba(185, 230, 255, 0.75), transparent 26%),
        linear-gradient(180deg, #fcf8f1 0%, #f7f0e4 100%);
      color: var(--theo-text);
      position: relative;
      overflow: hidden;
    }

    .theo-shell {
      position: relative;
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 20px 88px;
      z-index: 1;
    }

    .theo-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 34px;
    }

    .theo-brand {
      text-decoration: none;
      color: var(--theo-text);
      display: inline-flex;
      align-items: center;
    }

    .theo-brand-logo {
      display: block;
      width: clamp(132px, 18vw, 190px);
      height: auto;
    }

    .theo-nav-links {
      display: inline-flex;
      align-items: center;
      gap: 18px;
      flex-wrap: wrap;
    }

    .theo-nav-links a {
      color: var(--theo-stone);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 600;
    }

    .theo-nav-links a:hover {
      color: var(--theo-text);
    }

    .theo-nav-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 0 18px;
      border-radius: 999px;
      background: rgba(255,250,242,0.85);
      border: 1px solid rgba(99,87,66,0.14);
      color: var(--theo-text);
      text-decoration: none;
      font-weight: 700;
      box-shadow: 0 8px 20px rgba(99, 87, 66, 0.06);
    }

    .theo-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
      gap: 34px;
      align-items: center;
    }

    .theo-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(255,250,242,0.82);
      border: 1px solid rgba(149,130,99,0.14);
      color: var(--theo-slate);
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 18px;
      backdrop-filter: blur(10px);
    }

    .theo-title {
      margin: 0 0 16px;
      font-size: clamp(2.7rem, 7vw, 5.4rem);
      line-height: 0.94;
      letter-spacing: -0.07em;
      max-width: 10ch;
      color: var(--theo-text);
    }

    .theo-lead {
      max-width: 58ch;
      margin: 0;
      color: var(--theo-muted);
      font-size: 1.08rem;
      line-height: 1.72;
    }

    .theo-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
    }

    .theo-button,
    .theo-button-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      padding: 0 24px;
      border-radius: 999px;
      font-weight: 700;
      text-decoration: none;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .theo-button {
      background: var(--theo-blue);
      color: var(--theo-text);
      box-shadow: 0 14px 28px rgba(93, 115, 128, 0.14);
    }

    .theo-button:hover,
    .theo-button:focus-visible {
      transform: translateY(-1px);
      background: #a8ddfb;
    }

    .theo-button-secondary {
      background: rgba(255,250,242,0.84);
      border: 1px solid rgba(99,87,66,0.14);
      color: var(--theo-stone);
    }

    .theo-button-secondary:hover,
    .theo-button-secondary:focus-visible {
      transform: translateY(-1px);
      background: #fffaf2;
    }

    .theo-proof {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 26px;
      max-width: 620px;
    }

    .theo-proof-item {
      background: rgba(255,250,242,0.72);
      border: 1px solid rgba(99,87,66,0.1);
      border-radius: 20px;
      padding: 14px 16px;
    }

    .theo-proof-item strong {
      display: block;
      font-size: 0.86rem;
      color: var(--theo-text);
      margin-bottom: 6px;
    }

    .theo-proof-item span {
      color: var(--theo-muted);
      font-size: 0.86rem;
      line-height: 1.5;
    }

    .theo-phone {
      background: rgba(255,250,242,0.58);
      border: 1px solid rgba(99,87,66,0.1);
      border-radius: 34px;
      padding: 16px;
      box-shadow: 0 18px 48px rgba(99,87,66,0.08);
      backdrop-filter: blur(12px);
    }

    .theo-phone-screen {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      background: linear-gradient(180deg, #fcf8f1 0%, #f7f0e4 100%);
      border: 1px solid rgba(149,130,99,0.12);
      min-height: 620px;
      padding: 26px;
    }

    .theo-phone-screen::before,
    .theo-phone-screen::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      pointer-events: none;
    }

    .theo-phone-screen::before {
      width: 220px;
      height: 220px;
      left: -56px;
      top: -20px;
      background: rgba(198,173,132,0.48);
    }

    .theo-phone-screen::after {
      width: 280px;
      height: 280px;
      right: -80px;
      top: 108px;
      background: rgba(185,230,255,0.8);
    }

    .theo-ui {
      position: relative;
      z-index: 1;
    }

    .theo-ui-brand {
      font-size: 3.5rem;
      line-height: 0.88;
      letter-spacing: -0.08em;
      font-weight: 800;
      margin: 0;
    }

    .theo-ui-sub {
      font-size: 0.78rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--theo-slate);
      margin-top: 8px;
    }

    .theo-ui-headline {
      margin: 28px 0 10px;
      font-size: 2.15rem;
      line-height: 1.02;
      letter-spacing: -0.045em;
      max-width: 10ch;
    }

    .theo-ui-copy {
      max-width: 28ch;
      color: var(--theo-muted);
      line-height: 1.68;
      margin: 0 0 20px;
    }

    .theo-ui-card {
      border-radius: 28px;
      padding: 22px;
      border: 1px solid rgba(99,87,66,0.1);
      margin-top: 16px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
    }

    .theo-ui-card--warm {
      background: var(--theo-surface);
    }

    .theo-ui-card--cool {
      background: var(--theo-surface-soft);
    }

    .theo-ui-label {
      display: block;
      margin-bottom: 10px;
      color: var(--theo-slate);
      font-size: 0.76rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .theo-ui-card h3 {
      margin: 0 0 10px;
      font-size: 1.88rem;
      line-height: 1.06;
      letter-spacing: -0.035em;
    }

    .theo-ui-card p {
      margin: 0 0 14px;
      color: var(--theo-muted);
      line-height: 1.62;
    }

    .theo-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 15px;
      border-radius: 999px;
      background: rgba(255,250,242,0.88);
      border: 1px solid rgba(149,130,99,0.14);
      color: var(--theo-stone);
      font-size: 0.86rem;
      margin-bottom: 14px;
    }

    .theo-session {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      background: rgba(255,250,242,0.94);
      border-radius: 18px;
      padding: 16px 18px;
      margin-bottom: 14px;
    }

    .theo-session small {
      display: block;
      color: var(--theo-copper);
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .theo-session strong {
      display: block;
      font-size: 1.05rem;
    }

    .theo-session span {
      color: var(--theo-copper);
      font-size: 0.9rem;
      white-space: nowrap;
    }

    .theo-primary-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0 20px;
      border-radius: 999px;
      background: var(--theo-blue);
      color: var(--theo-text);
      font-weight: 700;
      text-decoration: none;
    }

    .theo-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      margin-top: 22px;
    }

    .theo-feature {
      background: rgba(255,250,242,0.76);
      border: 1px solid rgba(99,87,66,0.1);
      border-radius: 26px;
      padding: 24px;
    }

    .theo-feature h3 {
      margin: 0 0 10px;
      font-size: 1.28rem;
      letter-spacing: -0.03em;
    }

    .theo-feature p {
      margin: 0;
      color: var(--theo-muted);
      line-height: 1.66;
    }

    .theo-lower {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
      gap: 20px;
      margin-top: 20px;
    }

    .theo-panel {
      background: rgba(255,250,242,0.76);
      border: 1px solid rgba(99,87,66,0.1);
      border-radius: 28px;
      padding: 28px;
    }

    .theo-panel h2,
    .theo-legal-card h1,
    .theo-legal-card h2,
    .theo-support-card h1,
    .theo-support-card h2 {
      margin: 0 0 12px;
      line-height: 1.06;
      letter-spacing: -0.045em;
    }

    .theo-panel p,
    .theo-support-copy,
    .theo-legal-copy {
      margin: 0;
      color: var(--theo-muted);
      line-height: 1.72;
    }

    .theo-list {
      list-style: none;
      padding: 0;
      margin: 18px 0 0;
      display: grid;
      gap: 12px;
    }

    .theo-list li {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      color: var(--theo-muted);
      line-height: 1.64;
    }

    .theo-list li::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--theo-blue);
      flex: 0 0 auto;
      margin-top: 0.46rem;
      box-shadow: 0 0 0 5px rgba(185,230,255,0.25);
    }

    .theo-support-card,
    .theo-legal-card {
      max-width: 840px;
      margin: 0 auto;
      background: rgba(255,250,242,0.82);
      border: 1px solid rgba(99,87,66,0.1);
      border-radius: 30px;
      padding: 34px 28px;
    }

    .theo-meta {
      display: grid;
      gap: 14px;
      margin-top: 22px;
    }

    .theo-meta-item {
      background: rgba(238,246,251,0.72);
      border: 1px solid rgba(139,173,192,0.22);
      border-radius: 20px;
      padding: 16px 18px;
    }

    .theo-meta-item strong {
      display: block;
      margin-bottom: 6px;
      font-size: 0.94rem;
      color: var(--theo-text);
    }

    .theo-meta-item span,
    .theo-meta-item a {
      color: var(--theo-muted);
      text-decoration: none;
      line-height: 1.6;
    }

    .theo-meta-item a:hover {
      text-decoration: underline;
      color: var(--theo-text);
    }

    .theo-rte {
      margin-top: 24px;
      color: var(--theo-muted);
      line-height: 1.76;
      white-space: pre-line;
    }

    .theo-page--support .theo-hero,
    .theo-page--privacy .theo-hero,
    .theo-page--terms .theo-hero {
      grid-template-columns: 1fr;
    }

    .theo-footer {
      margin-top: 26px;
      padding-top: 20px;
      border-top: 1px solid rgba(99,87,66,0.08);
      display: flex;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
      color: var(--theo-muted);
      font-size: 0.92rem;
    }

    .theo-footer a {
      color: var(--theo-stone);
      text-decoration: none;
      margin-right: 14px;
    }

    .theo-footer a:hover {
      text-decoration: underline;
    }

    @media screen and (max-width: 989px) {
      .theo-hero,
      .theo-grid,
      .theo-lower,
      .theo-proof {
        grid-template-columns: 1fr;
      }

      .theo-phone-screen {
        min-height: auto;
      }
    }

    @media screen and (max-width: 749px) {
      .theo-shell {
        padding: 20px 16px 60px;
      }

      .theo-nav {
        align-items: flex-start;
        flex-direction: column;
      }

      .theo-nav-links {
        width: 100%;
        justify-content: space-between;
        gap: 12px;
      }

      .theo-actions {
        flex-direction: column;
      }

      .theo-button,
      .theo-button-secondary,
      .theo-nav-cta,
      .theo-primary-chip {
        width: 100%;
      }

      .theo-title {
        max-width: none;
      }

      .theo-phone,
      .theo-phone-screen,
      .theo-feature,
      .theo-panel,
      .theo-support-card,
      .theo-legal-card {
        border-radius: 24px;
      }
    }
  </style>

  <div class="theo-shell">
    <nav class="theo-nav" aria-label="Theo">
      <a class="theo-brand" href="/" aria-label="Theo home">
        <img class="theo-brand-logo" src="{{ 'theo-logo.png' | asset_url }}" alt="Theo">
      </a>

      <div class="theo-nav-links">
        <a href="https://theo.coach/pages/contact">Support</a>
        <a href="https://theo.coach/pages/privacy-policy">Privacy</a>
        <a href="https://theo.coach/pages/terms-of-service">Terms</a>
        <a class="theo-nav-cta" href="{{ section.settings.primary_button_link | default: '#' }}">{{ section.settings.primary_button_text }}</a>
      </div>
    </nav>

    {% case section.settings.page_variant %}
      {% when 'home' %}
        <div class="theo-hero">
          <div>
            <span class="theo-eyebrow">AI mindset coach for athletes</span>
            <h1 class="theo-title">Your journal, but spoken out loud.</h1>
            <p class="theo-lead">Theo is a voice-first AI mindset coach built for athletes and performance-focused people who want reflection to feel more natural, more consistent, and actually useful over time.</p>

            <div class="theo-actions">
              <a class="theo-button" href="{{ section.settings.primary_button_link | default: '#' }}">{{ section.settings.primary_button_text }}</a>
              <a class="theo-button-secondary" href="/pages/support">Support</a>
            </div>

            <div class="theo-proof">
              <div class="theo-proof-item">
                <strong>Voice-first</strong>
                <span>Talk instead of typing your journal every day.</span>
              </div>
              <div class="theo-proof-item">
                <strong>AI-supported</strong>
                <span>Patterns, routines, and reflections become more useful over time.</span>
              </div>
              <div class="theo-proof-item">
                <strong>Performance-minded</strong>
                <span>Made for calm, clarity, and focus before big moments.</span>
              </div>
            </div>
          </div>

          <div class="theo-phone">
            <div class="theo-phone-screen">
              <div class="theo-ui">
                <h2 class="theo-ui-brand">theo</h2>
                <div class="theo-ui-sub">Mindset coach</div>
                <h3 class="theo-ui-headline">Your journal, but spoken out loud.</h3>
                <p class="theo-ui-copy">Daily spoken reflection that helps you reset, stay grounded, and show up sharper.</p>

                <div class="theo-ui-card theo-ui-card--warm">
                  <span class="theo-ui-label">Today's session</span>
                  <h3>Morning daily check-in is ready.</h3>
                  <p>Your saved practices are ready to be worked through live with Theo whenever you check in.</p>
                  <div class="theo-chip">Streak · 6 days 🔥</div>
                  <div class="theo-session">
                    <div>
                      <small>Morning</small>
                      <strong>Journaling</strong>
                    </div>
                    <span>5 prompts</span>
                  </div>
                  <span class="theo-primary-chip">Start voice check-in →</span>
                </div>

                <div class="theo-ui-card theo-ui-card--cool">
                  <span class="theo-ui-label">Theo remembers</span>
                  <h3>Your patterns should come back when they matter.</h3>
                  <p>Theo helps turn repeated reflection into useful memory, so pressure moments feel calmer and more prepared.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="theo-grid">
          <div class="theo-feature">
            <h3>Talk instead of type</h3>
            <p>Daily journaling becomes a conversation, which makes consistency far easier than staring at a blank notes page.</p>
          </div>
          <div class="theo-feature">
            <h3>Reflect. Reset. Perform.</h3>
            <p>Use Theo before training, after competition, or during any moment where your mindset needs a calm reset.</p>
          </div>
          <div class="theo-feature">
            <h3>Useful memory over time</h3>
            <p>Theo is built to understand recurring patterns, routines, and focus areas so your reflection compounds instead of disappearing.</p>
          </div>
        </div>

        <div class="theo-lower">
          <div class="theo-panel">
            <h2>A calmer kind of performance tool.</h2>
            <p>Theo sits somewhere between a voice journal, a reflective AI companion, and a mindset coach. It is designed to feel premium, grounded, modern, and supportive without sounding clinical or generic-tech.</p>
            <ul class="theo-list">
              <li>Daily mindset check-ins</li>
              <li>Voice journaling for athletes</li>
              <li>Pre-event focus conversations</li>
              <li>Reflection after training or competition</li>
            </ul>
          </div>

          <div class="theo-panel">
            <h2>Important note</h2>
            <p>Theo is not a psychologist, therapist, crisis service, or medical provider. It is a mindset and reflection tool designed to support clarity, consistency, and performance-oriented journaling.</p>
            <ul class="theo-list">
              <li>Not for diagnosis or treatment</li>
              <li>Not a replacement for mental health professionals</li>
              <li>Use qualified professionals for clinical care</li>
            </ul>
          </div>
        </div>

      {% when 'support' %}
        <div class="theo-hero">
          <div class="theo-support-card">
            <span class="theo-eyebrow">Theo support</span>
            <h1 class="theo-title" style="max-width:none;">Need help with Theo?</h1>
            <p class="theo-support-copy">If you need help with account access, subscriptions, app issues, privacy questions, or data deletion requests, use the details below and we’ll get back to you as soon as we can.</p>

            <div class="theo-meta">
              <div class="theo-meta-item">
                <strong>Support email</strong>
                <a href="mailto:{{ section.settings.support_email }}">{{ section.settings.support_email }}</a>
              </div>
              <div class="theo-meta-item">
                <strong>Website</strong>
                <a href="{{ section.settings.website_url }}">{{ section.settings.website_url }}</a>
              </div>
              <div class="theo-meta-item">
                <strong>Response window</strong>
                <span>{{ section.settings.response_window }}</span>
              </div>
            </div>

            <div class="theo-rte">{{ section.settings.support_text | newline_to_br }}</div>
          </div>
        </div>

      {% when 'privacy' %}
        <div class="theo-hero">
          <div class="theo-legal-card">
            <span class="theo-eyebrow">Legal</span>
            <h1 class="theo-title" style="max-width:none;">Privacy Policy</h1>
            <p class="theo-legal-copy">This page explains what Theo collects, why it is collected, how it may be used, and how users can contact you about privacy, deletion, or access requests.</p>
            <div class="theo-rte">{{ section.settings.privacy_text | newline_to_br }}</div>
          </div>
        </div>

      {% when 'terms' %}
        <div class="theo-hero">
          <div class="theo-legal-card">
            <span class="theo-eyebrow">Legal</span>
            <h1 class="theo-title" style="max-width:none;">Terms of Service</h1>
            <p class="theo-legal-copy">This page should cover app use, eligibility, subscriptions, acceptable use, disclaimers, limitation of liability, and support contact details.</p>
            <div class="theo-rte">{{ section.settings.terms_text | newline_to_br }}</div>
          </div>
        </div>
    {% endcase %}

    <div class="theo-footer">
      <div>© {{ 'now' | date: '%Y' }} Theo</div>
      <div>
        <a href="https://theo.coach/pages/contact">Support</a>
        <a href="https://theo.coach/pages/privacy-policy">Privacy</a>
        <a href="https://theo.coach/pages/terms-of-service">Terms</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Theo marketing",
  "settings": [
    {
      "type": "select",
      "id": "page_variant",
      "label": "Page variant",
      "options": [
        { "value": "home", "label": "Home" },
        { "value": "support", "label": "Support" },
        { "value": "privacy", "label": "Privacy" },
        { "value": "terms", "label": "Terms" }
      ],
      "default": "home"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "Download on the App Store"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@theo.coach"
    },
    {
      "type": "text",
      "id": "website_url",
      "label": "Website URL",
